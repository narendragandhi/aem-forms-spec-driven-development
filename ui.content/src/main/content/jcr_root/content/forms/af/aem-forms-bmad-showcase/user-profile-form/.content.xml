<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:lastModified="{Date}2026-02-18T16:15:00.000Z"
        cq:lastModifiedBy="admin"
        cq:template="/conf/aem-forms-bmad-showcase/settings/wcm/templates/standard-application"
        jcr:primaryType="cq:PageContent"
        jcr:title="User Profile Form"
        sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/page"
        guideComponentType="fd/af/components/page"
        fdm="user-profile-fdm"
        dataRef="/conf/aem-forms-bmad-showcase/settings/fdm/user-profile-fdm">
        <guideContainer
            jcr:primaryType="nt:unstructured"
            sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/formcontainer"
            editable="{Boolean}true"
            guideNodeClass="guideContainerNode"
            schemaRef="/conf/aem-forms-bmad-showcase/settings/fdm/user-profile-fdm/schemas/user-profile.schema.json">
            <rootPanel
                jcr:primaryType="nt:unstructured"
                sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/panel"
                name="rootPanel"
                paneltype="simple"
                layout="responsiveGrid">
                <items jcr:primaryType="nt:unstructured">
                    <panel1
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/panel"
                        name="panel1"
                        paneltype="simple"
                        layout="responsiveGrid"
                        jcr:title="Personal Information">
                        <items jcr:primaryType="nt:unstructured">
                            <firstname
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/textinput"
                                name="firstName"
                                propertyName="firstName"
                                bindRef="firstName"
                                fieldType="text-input"
                                label="First Name"/>
                            <lastname
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/textinput"
                                name="lastName"
                                propertyName="lastName"
                                bindRef="lastName"
                                fieldType="text-input"
                                label="Last Name"/>
                            <email
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/emailinput"
                                name="email"
                                propertyName="email"
                                bindRef="email"
                                fieldType="email-input"
                                label="Email"/>
                            <addresslookup
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/addresslookup"
                                name="addressLookup"
                                propertyName="address"
                                bindRef="address"
                                fieldType="custom-component"
                                label="Address"/>
                        </items>
                    </panel1>
                </items>
            </rootPanel>
        </guideContainer>
    </jcr:content>
</jcr:root>
