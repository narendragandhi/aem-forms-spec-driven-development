<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:lastModified="{Date}2026-03-10T10:00:00.000Z"
        cq:lastModifiedBy="admin"
        cq:template="/conf/aem-forms-bmad-showcase/settings/wcm/templates/standard-application"
        jcr:primaryType="cq:PageContent"
        jcr:title="Financial Services Application"
        sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/page"
        guideComponentType="fd/af/components/page">
        <guideContainer
            jcr:primaryType="nt:unstructured"
            sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/formcontainer"
            editable="{Boolean}true"
            guideNodeClass="guideContainerNode">
            <rootPanel
                jcr:primaryType="nt:unstructured"
                sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/panel"
                name="rootPanel"
                paneltype="simple"
                layout="wizard">
                <items jcr:primaryType="nt:unstructured">
                    <personalPanel
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/panel"
                        name="personalPanel"
                        jcr:title="Personal Details"
                        layout="responsiveGrid">
                        <items jcr:primaryType="nt:unstructured">
                            <fullName
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/textinput"
                                name="fullName"
                                fieldType="text-input"
                                label="Full Name"/>
                            <income
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/numberinput"
                                name="annualIncome"
                                fieldType="number-input"
                                label="Annual Income"
                                leadNotation="$"/>
                        </items>
                    </personalPanel>
                    <employmentPanel
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/panel"
                        name="employmentPanel"
                        jcr:title="Employment History"
                        layout="responsiveGrid">
                        <items jcr:primaryType="nt:unstructured">
                            <employmentTable
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/table"
                                name="employmentTable"
                                jcr:title="Previous Employment"
                                initialRows="{Long}1"
                                minOccur="{Long}1"
                                maxOccur="{Long}5">
                                <items jcr:primaryType="nt:unstructured">
                                    <row1
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/tablerow"
                                        name="row1">
                                        <items jcr:primaryType="nt:unstructured">
                                            <company
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/textinput"
                                                name="company"
                                                label="Company Name"/>
                                            <role
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/textinput"
                                                name="role"
                                                label="Role"/>
                                            <years
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="aem-forms-bmad-showcase/components/adaptiveForm/numberinput"
                                                name="years"
                                                label="Years of Service"/>
                                        </items>
                                    </row1>
                                </items>
                            </employmentTable>
                        </items>
                    </employmentPanel>
                </items>
            </rootPanel>
        </guideContainer>
    </jcr:content>
</jcr:root>
