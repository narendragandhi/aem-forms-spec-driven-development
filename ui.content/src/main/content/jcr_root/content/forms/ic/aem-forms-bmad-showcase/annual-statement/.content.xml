<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:lastModified="{Date}2026-03-10T10:15:00.000Z"
        cq:lastModifiedBy="admin"
        jcr:primaryType="cq:PageContent"
        jcr:title="Annual Account Statement"
        sling:resourceType="fd/ic/components/page/basepage">
        <rootContainer
            jcr:primaryType="nt:unstructured"
            sling:resourceType="fd/ic/components/container/rootcontainer">
            <items jcr:primaryType="nt:unstructured">
                <header
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="fd/ic/components/content/text"
                    text="Annual Financial Summary for ${customerName}"/>
                <transactionTable
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="fd/ic/components/content/table"
                    name="transactionTable"
                    jcr:title="Recent Transactions">
                    <items jcr:primaryType="nt:unstructured">
                        <headerRow
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="fd/ic/components/content/tablerow"
                            rowType="header">
                            <items jcr:primaryType="nt:unstructured">
                                <col1 jcr:primaryType="nt:unstructured" text="Date"/>
                                <col2 jcr:primaryType="nt:unstructured" text="Description"/>
                                <col3 jcr:primaryType="nt:unstructured" text="Amount"/>
                            </items>
                        </headerRow>
                        <dataRow
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="fd/ic/components/content/tablerow"
                            rowType="body"
                            bindRef="$.transactions[*]">
                            <items jcr:primaryType="nt:unstructured">
                                <date
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="fd/ic/components/content/text"
                                    bindRef="date"/>
                                <desc
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="fd/ic/components/content/text"
                                    bindRef="description"/>
                                <amount
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="fd/ic/components/content/text"
                                    bindRef="amount"/>
                            </items>
                        </dataRow>
                    </items>
                </transactionTable>
            </items>
        </rootContainer>
    </jcr:content>
</jcr:root>
