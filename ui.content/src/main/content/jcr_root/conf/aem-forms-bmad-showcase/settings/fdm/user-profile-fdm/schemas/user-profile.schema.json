{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User Profile Schema",
  "description": "Schema for capturing user profile information",
  "type": "object",
  "properties": {
    "firstName": {
      "type": "string",
      "description": "User's first name"
    },
    "lastName": {
      "type": "string",
      "description": "User's last name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "User's email address"
    },
    "userId": {
      "type": "string",
      "description": "Unique user ID (e.g., from AEM profile)"
    },
    "address": {
      "type": "object",
      "description": "User's address details",
      "properties": {
        "street": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "postalCode": {
          "type": "string"
        },
        "country": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "firstName",
    "lastName",
    "email"
  ]
}
