{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BEAD Agent Context",
  "description": "Shared memory schema for AI agent state persistence across sessions",
  "type": "object",
  "properties": {
    "agent": {
      "type": "string",
      "description": "Agent identifier (coder, tester, reviewer, dispatcher, docs, mayor)"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last context update"
    },
    "session_count": {
      "type": "integer",
      "description": "Number of sessions this agent has participated in"
    },
    "current_workflow": {
      "type": ["object", "null"],
      "description": "Active workflow context",
      "properties": {
        "workflow_id": { "type": "string" },
        "workflow_name": { "type": "string" },
        "started_at": { "type": "string", "format": "date-time" },
        "phase": { "type": "string" }
      }
    },
    "active_issues": {
      "type": "array",
      "description": "Currently assigned issues being worked on",
      "items": {
        "type": "object",
        "properties": {
          "issue_id": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "in_progress", "blocked"] },
          "started_at": { "type": "string", "format": "date-time" },
          "last_action": { "type": "string" }
        }
      }
    },
    "completed_issues": {
      "type": "array",
      "description": "Recently completed issues (last 10)",
      "items": {
        "type": "object",
        "properties": {
          "issue_id": { "type": "string" },
          "completed_at": { "type": "string", "format": "date-time" },
          "outcome": { "type": "string", "enum": ["success", "cancelled", "handed_off"] }
        }
      },
      "maxItems": 10
    },
    "dependencies": {
      "type": "object",
      "description": "Dependency tracking",
      "properties": {
        "waiting_on": {
          "type": "array",
          "description": "Issues this agent is blocked by",
          "items": {
            "type": "object",
            "properties": {
              "issue_id": { "type": "string" },
              "blocking_agent": { "type": "string" },
              "since": { "type": "string", "format": "date-time" }
            }
          }
        },
        "blocking": {
          "type": "array",
          "description": "Issues waiting on this agent",
          "items": {
            "type": "object",
            "properties": {
              "issue_id": { "type": "string" },
              "waiting_agent": { "type": "string" }
            }
          }
        }
      }
    },
    "handoffs": {
      "type": "object",
      "description": "Inter-agent communication queue",
      "properties": {
        "inbox": {
          "type": "array",
          "description": "Messages received from other agents",
          "items": {
            "type": "object",
            "properties": {
              "from_agent": { "type": "string" },
              "issue_id": { "type": "string" },
              "message": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "read": { "type": "boolean" }
            }
          }
        },
        "outbox": {
          "type": "array",
          "description": "Messages sent to other agents (for audit)",
          "items": {
            "type": "object",
            "properties": {
              "to_agent": { "type": "string" },
              "issue_id": { "type": "string" },
              "message": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "description": "Agent performance metrics",
      "properties": {
        "issues_completed": { "type": "integer" },
        "avg_completion_time_hours": { "type": "number" },
        "issues_blocked": { "type": "integer" },
        "handoffs_sent": { "type": "integer" },
        "handoffs_received": { "type": "integer" }
      }
    },
    "preferences": {
      "type": "object",
      "description": "Agent-specific settings and learned preferences",
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "description": "Persistent notes for cross-session memory",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "category": { "type": "string" },
          "content": { "type": "string" }
        }
      }
    }
  },
  "required": ["agent", "last_updated", "session_count"]
}
